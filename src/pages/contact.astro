---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContactCard from '../components/ContactCard.astro';
import profile from '../data/profile.json';
import contact from '../data/contact.json';
---

<BaseLayout
  title="Contact"
  description={`Contact ${profile.name}, open to collaborations, research discussions, and opportunities.`}
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <SectionHeader
      eyebrow="Get in Touch"
      title="Contact"
      subtitle="I am open to research collaborations, industry opportunities, and conversations about intelligent networking, video streaming, and applied ML. The fastest way to reach me is by email."
    />

    <ContactCard />

    <div class="reveal mt-10 rounded-2xl border border-brand-200 bg-brand-50 p-6 dark:border-brand-900 dark:bg-ink-900/60">
      <h2 class="font-bold text-slate-900 dark:text-white">Looking for my CV or papers?</h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        You can find my publication list with PDFs on the
        <a href="/publications/" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">publications page</a>{
          profile.cv && (
            <>
              {' '}and download my CV{' '}
              <a
                href={profile.cv}
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-brand-600 hover:underline dark:text-brand-400"
              >
                here
              </a>
            </>
          )
        }. For anything else, email
        <a
          href={`mailto:${contact.email}`}
          class="font-semibold text-brand-600 hover:underline dark:text-brand-400"
        >
          {contact.email}
        </a>.
      </p>
    </div>
  </section>
</BaseLayout>
