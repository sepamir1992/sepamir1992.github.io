---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import profile from '../data/profile.json';
import contact from '../data/contact.json';

const publications = (await getCollection('publications')).sort(
  (a, b) => b.data.year - a.data.year
);

const education = [
  {
    school: 'University of Victoria',
    location: 'Victoria, BC, Canada',
    degree: 'Ph.D. Candidate in Electrical and Computer Engineering — GPA: 9.0 / 9.0',
    period: '2021 – Present',
    details:
      'Supervisor: Dr. Lin Cai (IEEE Fellow) · Focus: AI/ML, Wireless Communications, Internet Protocols, Network Security',
    thesis:
      'AI-Driven Multipath Scheduling in Heterogeneous Mobile Networks: Meta-Learning, Federated Optimization, and On-Device Intent-Aware Control',
  },
  {
    school: 'Isfahan University of Technology',
    location: 'Isfahan, Iran',
    degree: 'M.Sc. in Communication Networks — GPA: 3.90 / 4.0',
    period: '2016 – 2019',
    details: 'Ranked 1st among Communication Networks M.Sc. students',
    thesis: 'Controller Placement in Software-Defined Networks using Dominating Set',
  },
];

interface GsiItem {
  title: string;
  note?: string;
  goal: string;
  solution: string;
  impact: string;
}

const doctoralResearch: GsiItem[] = [
  {
    title: 'KESTREL — On-Device Intent-Aware Multipath Scheduling',
    goal: 'Bring intelligent MPQUIC scheduling onto resource-constrained mobile devices, where cloud-scale RL models are infeasible and application intent (latency vs. throughput vs. energy) is ignored by existing schedulers.',
    solution:
      'Architected a split-loop design separating a lightweight on-device fast path from a slower learning loop, with intent-aware policies trained on oracle-labeled traces from a custom Android data-collection pipeline.',
    impact:
      'Enables real-time, intent-aligned path selection fully on-device; manuscript in preparation for IEEE Transactions on Mobile Computing, with a live Android deployment strengthening the systems contribution.',
  },
  {
    title: 'Fed-MVP — Federated Multipath Video Streaming',
    note: 'funded by DND Canada',
    goal: 'Adapt multipath video streaming to heterogeneous, fast-changing network conditions without centralizing sensitive client data.',
    solution:
      'Built a hierarchical federated learning protocol with distributed meta-models at edge servers, enabling clients to personalize schedulers locally while sharing only model updates.',
    impact:
      'Reduced video stalling by 35% and improved average video quality by 20% over baselines; published in IEEE/ACM Transactions on Networking.',
  },
  {
    title: 'LSMeta-DAMS — Meta-RL Delay-Aware Multipath Scheduler',
    goal: 'Overcome the slow convergence of RL-based schedulers, which fail when network conditions shift faster than models can retrain.',
    solution:
      'Developed a hybrid meta-reinforcement learning scheduler that learns an adaptation prior across network environments, fine-tuning to unseen conditions within a few gradient steps.',
    impact:
      'Delivered fast, delay-aware adaptation for live video streaming over MPQUIC; published in IEEE Transactions on Cognitive Communications and Networking and IEEE VTC2023-Fall.',
  },
];

const ericssonProjects: GsiItem[] = [
  {
    title: 'Enterprise RAG-Based Search Engine',
    goal: 'Engineers lost hours searching millions of JIRA tickets and fragmented documentation for known fixes.',
    solution:
      'Architected a hybrid search system (LangChain + Weaviate) combining keyword and semantic retrieval with cross-encoder reranking; containerized with Docker, orchestrated via Kubeflow, and deployed through GitLab CI/CD.',
    impact:
      'Cut solution discovery from hours to seconds; a DeepEval pipeline with an engineer-curated ground-truth set benchmarked hallucination and retrieval accuracy before production rollout.',
  },
  {
    title: 'Intent-Based Network Automation (Mission-Critical Networks)',
    goal: 'Manual RAN/Core configuration consumed hours per deployment cycle and reacted to SLA violations only after degradation.',
    solution:
      'Integrated LLMs to translate natural-language intents into executable network policies, and built time-series forecasting models (AutoReg, LightGBM, ARIMA) for throughput, latency, and user-mobility KPIs, served through a real-time InfluxDB + Grafana telemetry pipeline.',
    impact:
      'Eliminated hours of manual configuration per deployment and exposed prediction APIs that let operators preemptively reroute resources in high-mobility scenarios.',
  },
  {
    title: 'Centralized AI Platform ("AI Hub")',
    goal: 'Fragmented, team-by-team evaluation workflows slowed telecom AI model selection and research-to-production handoff.',
    solution:
      'Collaborated with Université de Montréal to build a centralized single-pane-of-glass dashboard for benchmarking AI models across teams.',
    impact:
      'Accelerated model selection and measurably reduced research-to-production handoff time across GAIA teams.',
  },
];

const selectedProjects: GsiItem[] = [
  {
    title: 'Course Scheduler — Project Manager, University of Victoria',
    note: 'May – Aug 2023',
    goal: 'Canadian universities relied on manual, conflict-prone course scheduling that took weeks per term.',
    solution:
      'Led a multi-team effort (frontend, backend, database, algorithms) to build scheduling software balancing student preferences, faculty availability, and classroom resources.',
    impact:
      'Reduced scheduling conflicts by 70% and compressed scheduling time from 3 weeks to 2 days.',
  },
  {
    title: 'WARP Full-Duplex Algorithm — TÜBİTAK & Sabancı University, Istanbul',
    note: 'Oct 2020 – Aug 2021',
    goal: 'Half-duplex operation in the 802.11 reference design left substantial wireless capacity unused on WARP hardware.',
    solution:
      'Developed a full-duplex algorithm by modifying MAC-layer C code in the 802.11 reference design for WARP nodes.',
    impact: 'Achieved a 45% throughput increase and 37% latency reduction over the half-duplex baseline.',
  },
  {
    title: 'SDN Infrastructure & Implementation — Isfahan University of Technology',
    note: 'Summer 2018',
    goal: 'Legacy campus networking was costly to operate, slow to reconfigure, and difficult to scale.',
    solution:
      'Deployed virtualized campus infrastructure (Cisco routers, MikroTik APs, Raspberry Pi sensors) and an SDN testbed using Mininet with a Floodlight controller.',
    impact:
      'Sustained 99.9% uptime with a 30% hardware-cost reduction; improved network scalability by 60% and cut configuration time by 48%.',
  },
];

const skills = [
  { label: 'Languages', value: 'Python, C/C++, SQL' },
  { label: 'AI/ML', value: 'PyTorch, TensorFlow, Keras, Scikit-learn' },
  { label: 'LLM & GenAI', value: 'LangChain, Amazon Bedrock, DeepEval, Weaviate' },
  { label: 'Networking', value: 'NS-3, Mininet, Wireshark, Cisco Packet Tracer' },
  { label: 'DevOps & MLOps', value: 'GitLab CI/CD, Docker, Kubernetes, Kubeflow, Azure' },
  { label: 'Data & Visualization', value: 'InfluxDB, ChromaDB, Power BI, Grafana, Matplotlib' },
  { label: 'Quantum', value: 'Qiskit' },
];

const honors = [
  'Elected ECE Graduate Student Representative & GSS Financial Committee Member, University of Victoria, 2021',
  'Ranked 1st among Communication Networks M.Sc. students, Isfahan University of Technology, 2019',
  'Ranked 5th among B.Sc. Communication Engineering students, Yazd University, 2014',
];

const certifications =
  'Google Cybersecurity Professional Certificate (in progress) · NVIDIA GenAI & DRL for Anomaly Detection · Deep Learning Specialization · Firewalls & Intrusion Prevention Systems · CCNA (IEEE)';

const teachingCourses =
  'Real-Time Computer Systems (ECE 455, 2022–2026); Computer Networks (CSC 361, 2022–2026); Computer Architecture (ECE 255, 2022–2026); Project Management & Engineering Economics (ENGR 003/004); Design Project II (SENG 499); Intro to ECE Design (ECE 299); IoT (CSC 569); Communications Theory and Systems I (ECE 350)';

const statusLabels: Record<string, string> = {
  published: '',
  accepted: ' (accepted)',
  'under-review': ' (under review)',
  preprint: ' (preprint)',
  'in-preparation': ' (in preparation)',
};
---

<BaseLayout
  title="CV"
  description={`Curriculum vitae of ${profile.name} — education, research, professional experience, publications, and skills.`}
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <SectionHeader
      eyebrow="Curriculum Vitae"
      title="CV"
      subtitle="Ph.D. Candidate, Electrical & Computer Engineering · AI/ML for Networked Systems"
    />

    <div class="reveal -mt-4 mb-12 flex flex-wrap gap-3">
      {
        profile.cv && (
          <a
            href={profile.cv}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 transition-all hover:-translate-y-0.5 hover:bg-brand-500"
          >
            Download PDF
          </a>
        )
      }
      <a
        href={contact.scholar}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-ink-700 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
      >
        Google Scholar ↗
      </a>
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition-all hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-600 dark:border-ink-700 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
      >
        LinkedIn ↗
      </a>
    </div>

    <!-- Education -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Education
      </h2>
      <div class="space-y-6">
        {
          education.map((edu) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-bold text-slate-900 dark:text-white">{edu.school}</h3>
                <span class="text-sm text-slate-400 dark:text-slate-500">
                  {edu.location} · {edu.period}
                </span>
              </div>
              <p class="mt-0.5 text-sm font-medium text-brand-600 dark:text-brand-400">
                {edu.degree}
              </p>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{edu.details}</p>
              <p class="mt-1 text-sm italic text-slate-500 dark:text-slate-400">
                Thesis: {edu.thesis}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Research experience -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Research Experience
      </h2>
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-bold text-slate-900 dark:text-white">
          University of Victoria — Doctoral Research
        </h3>
        <span class="text-sm text-slate-400 dark:text-slate-500">2021 – Present</span>
      </div>
      <p class="mt-0.5 text-sm font-medium text-brand-600 dark:text-brand-400">
        Full-time Research Assistant, Multipath Networking & Distributed AI
      </p>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        Designed three successive AI-driven multipath scheduling systems, each published or in
        preparation for top IEEE/ACM venues:
      </p>
      <div class="mt-4 space-y-5">
        {
          doctoralResearch.map((item) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-ink-800 dark:bg-ink-900/60">
              <p class="font-semibold text-slate-900 dark:text-white">
                {item.title}
                {item.note && (
                  <span class="ml-2 text-xs font-medium text-slate-400 dark:text-slate-500">
                    {item.note}
                  </span>
                )}
              </p>
              <dl class="mt-2 space-y-1.5 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Goal&nbsp;</dt>
                  <dd class="inline">{item.goal}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Solution&nbsp;</dt>
                  <dd class="inline">{item.solution}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Impact&nbsp;</dt>
                  <dd class="inline">{item.impact}</dd>
                </div>
              </dl>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Professional experience -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Professional Experience
      </h2>
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-bold text-slate-900 dark:text-white">
          Ericsson — Global AI Accelerator (GAIA)
        </h3>
        <span class="text-sm text-slate-400 dark:text-slate-500">
          Montreal, Canada · Jan 2025 – Dec 2025
        </span>
      </div>
      <p class="mt-0.5 text-sm font-medium text-brand-600 dark:text-brand-400">
        Machine Learning Engineer Intern
      </p>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        Led end-to-end development of GenAI and predictive modeling solutions for 5G/6G networks
        across three flagship projects:
      </p>
      <div class="mt-4 space-y-5">
        {
          ericssonProjects.map((item) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-ink-800 dark:bg-ink-900/60">
              <p class="font-semibold text-slate-900 dark:text-white">{item.title}</p>
              <dl class="mt-2 space-y-1.5 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Goal&nbsp;</dt>
                  <dd class="inline">{item.goal}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Solution&nbsp;</dt>
                  <dd class="inline">{item.solution}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Impact&nbsp;</dt>
                  <dd class="inline">{item.impact}</dd>
                </div>
              </dl>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Teaching -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Teaching Experience
      </h2>
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-bold text-slate-900 dark:text-white">University of Victoria</h3>
        <span class="text-sm text-slate-400 dark:text-slate-500">2021 – Present</span>
      </div>
      <p class="mt-0.5 text-sm font-medium text-brand-600 dark:text-brand-400">
        Teaching Assistant — 8 courses across systems, networking, and software engineering
      </p>
      <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        <li>{teachingCourses}.</li>
        <li>
          Delivered tutorials in programming (C, Python), mathematics, statistics, econometrics,
          and networking (CCNA), 2018–2026.
        </li>
      </ul>
    </div>

    <!-- Publications -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Publications
      </h2>
      <ol class="space-y-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {
          publications.map((pub, i) => (
            <li class="flex gap-3">
              <span class="shrink-0 font-bold text-accent-600 dark:text-accent-400">
                [{i + 1}]
              </span>
              <span>
                {pub.data.authors}, “{pub.data.title},”{' '}
                <em>{pub.data.venue}</em>, {pub.data.year}
                {statusLabels[pub.data.status]}
                {pub.data.doi && <>, doi: {pub.data.doi}</>}.
              </span>
            </li>
          ))
        }
      </ol>
      <p class="mt-4 text-sm">
        <a
          href="/publications/"
          class="font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
        >
          Full publication list with abstracts and links <span aria-hidden="true">→</span>
        </a>
      </p>
    </div>

    <!-- Selected projects -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Selected Projects
      </h2>
      <div class="space-y-5">
        {
          selectedProjects.map((item) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-ink-800 dark:bg-ink-900/60">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <p class="font-semibold text-slate-900 dark:text-white">{item.title}</p>
                {item.note && (
                  <span class="text-xs font-medium text-slate-400 dark:text-slate-500">
                    {item.note}
                  </span>
                )}
              </div>
              <dl class="mt-2 space-y-1.5 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Goal&nbsp;</dt>
                  <dd class="inline">{item.goal}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Solution&nbsp;</dt>
                  <dd class="inline">{item.solution}</dd>
                </div>
                <div>
                  <dt class="inline font-bold uppercase tracking-wide text-accent-600 dark:text-accent-400">Impact&nbsp;</dt>
                  <dd class="inline">{item.impact}</dd>
                </div>
              </dl>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Skills -->
    <div class="reveal mb-12">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Technical Skills
      </h2>
      <dl class="grid gap-x-10 gap-y-3 sm:grid-cols-2">
        {
          skills.map((skill) => (
            <div class="text-sm">
              <dt class="font-bold text-slate-900 dark:text-white">{skill.label}</dt>
              <dd class="text-slate-600 dark:text-slate-400">{skill.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- Honors & certifications -->
    <div class="reveal">
      <h2 class="mb-5 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-ink-800 dark:text-white">
        Honors, Awards & Certifications
      </h2>
      <ul class="space-y-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {
          honors.map((honor) => (
            <li class="flex gap-3">
              <span class="mt-0.5 shrink-0 text-accent-500" aria-hidden="true">
                ★
              </span>
              {honor}
            </li>
          ))
        }
        <li class="flex gap-3">
          <span class="mt-0.5 shrink-0 text-brand-500" aria-hidden="true">✓</span>
          {certifications}
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
