---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
---

<div class:list={['reveal mb-10 max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {
    eyebrow && (
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-accent-500">{eyebrow}</p>
    )
  }
  <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-3 text-lg leading-relaxed text-slate-600 dark:text-slate-400">{subtitle}</p>
    )
  }
</div>
