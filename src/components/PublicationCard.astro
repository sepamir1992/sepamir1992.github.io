---
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
}

const { publication } = Astro.props;
const { title, authors, venue, year, status, doi, arxiv, pdf, bibtex, tags, abstract } =
  publication.data;

const statusLabels: Record<string, string> = {
  published: 'Published',
  accepted: 'Accepted',
  'under-review': 'Under Review',
  preprint: 'Preprint',
  'in-preparation': 'In Preparation',
};

const statusStyles: Record<string, string> = {
  published:
    'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
  accepted: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
  'under-review': 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
  preprint: 'bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-300',
  'in-preparation': 'bg-slate-100 text-slate-600 dark:bg-ink-800 dark:text-slate-300',
};

const links = [
  doi ? { label: 'DOI', href: doi.startsWith('http') ? doi : `https://doi.org/${doi}` } : null,
  arxiv ? { label: 'arXiv', href: arxiv } : null,
  pdf ? { label: 'PDF', href: pdf } : null,
].filter((l) => l !== null);

const cardId = `pub-${publication.id}`;
---

<article
  class="reveal rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all hover:border-brand-300 hover:shadow-lg dark:border-ink-800 dark:bg-ink-900/60 dark:hover:border-brand-700"
>
  <div class="flex flex-wrap items-start justify-between gap-2">
    <h3 class="max-w-2xl text-lg font-bold leading-snug text-slate-900 dark:text-white">
      {title}
    </h3>
    <div class="flex shrink-0 items-center gap-2">
      <span class:list={['rounded-full px-2.5 py-1 text-xs font-semibold', statusStyles[status]]}>
        {statusLabels[status]}
      </span>
      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600 dark:bg-ink-800 dark:text-slate-300">
        {year}
      </span>
    </div>
  </div>

  <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{authors}</p>
  {venue && <p class="mt-1 text-sm font-medium italic text-slate-500 dark:text-slate-400">{venue}</p>}

  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5" aria-label="Topics">
        {tags.map((tag) => (
          <li class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700 dark:bg-ink-800 dark:text-brand-300">
            {tag}
          </li>
        ))}
      </ul>
    )
  }

  <div class="mt-4 flex flex-wrap items-center gap-2">
    {
      links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 transition-colors hover:border-brand-400 hover:text-brand-600 dark:border-ink-700 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
        >
          {link.label}
        </a>
      ))
    }
    {
      abstract && (
        <button
          type="button"
          class="abstract-toggle rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 transition-colors hover:border-brand-400 hover:text-brand-600 dark:border-ink-700 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
          aria-expanded="false"
          aria-controls={`${cardId}-abstract`}
        >
          Abstract
        </button>
      )
    }
    {
      bibtex && (
        <button
          type="button"
          class="bibtex-toggle rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700 transition-colors hover:border-brand-400 hover:text-brand-600 dark:border-ink-700 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
          aria-expanded="false"
          aria-controls={`${cardId}-bibtex`}
        >
          BibTeX
        </button>
      )
    }
  </div>

  {
    abstract && (
      <div id={`${cardId}-abstract`} class="hidden" data-panel="abstract">
        <p class="mt-4 rounded-xl bg-slate-50 p-4 text-sm leading-relaxed text-slate-600 dark:bg-ink-950/60 dark:text-slate-400">
          {abstract}
        </p>
      </div>
    )
  }
  {
    bibtex && (
      <div id={`${cardId}-bibtex`} class="hidden" data-panel="bibtex">
        <pre class="mt-4 overflow-x-auto rounded-xl bg-slate-900 p-4 text-xs leading-relaxed text-slate-200 dark:bg-ink-950"><code>{bibtex}</code></pre>
      </div>
    )
  }
</article>

<script>
  // Toggle abstract/BibTeX panels per card.
  document.querySelectorAll('.abstract-toggle, .bibtex-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panelId = btn.getAttribute('aria-controls');
      const panel = panelId ? document.getElementById(panelId) : null;
      if (!panel) return;
      const nowHidden = panel.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!nowHidden));
    });
  });
</script>
