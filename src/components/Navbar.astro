---
import ThemeToggle from './ThemeToggle.astro';
import profile from '../data/profile.json';

const navLinks = [
  { href: '/about/', label: 'About' },
  { href: '/cv/', label: 'CV' },
  { href: '/research/', label: 'Research' },
  { href: '/projects/', label: 'Projects' },
  { href: '/publications/', label: 'Publications' },
];

const hobbies = [
  { href: '/photography/', label: 'Photography' },
  { href: '/games/', label: 'Video Games' },
];

const contactLink = { href: '/contact/', label: 'Contact' };

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href.replace(/\/$/, ''));
const hobbiesActive = hobbies.some((h) => isActive(h.href));

const linkClasses = (active: boolean) => [
  'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
  active
    ? 'bg-brand-50 text-brand-700 dark:bg-ink-900 dark:text-brand-300'
    : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-ink-900 dark:hover:text-white',
];
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/80 backdrop-blur-md dark:border-ink-800/70 dark:bg-ink-950/80"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6" aria-label="Main navigation">
    <a
      href="/"
      class="text-lg font-bold tracking-tight text-slate-900 transition-colors hover:text-brand-600 dark:text-white dark:hover:text-brand-400"
    >
      {profile.name}
    </a>

    <div class="flex items-center gap-2">
      <ul class="hidden items-center gap-1 md:flex">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class:list={linkClasses(isActive(link.href))}
              >
                {link.label}
              </a>
            </li>
          ))
        }

        <li class="relative" id="hobbies-root">
          <button
            id="hobbies-button"
            type="button"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="hobbies-dropdown"
            class:list={[linkClasses(hobbiesActive), 'inline-flex items-center gap-1']}
          >
            Hobbies
            <svg class="h-3.5 w-3.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <ul
            id="hobbies-dropdown"
            class="absolute right-0 top-full mt-2 hidden w-44 rounded-xl border border-slate-200 bg-white p-1.5 shadow-xl dark:border-ink-800 dark:bg-ink-900"
          >
            {
              hobbies.map((hobby) => (
                <li>
                  <a
                    href={hobby.href}
                    aria-current={isActive(hobby.href) ? 'page' : undefined}
                    class:list={[
                      'block rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                      isActive(hobby.href)
                        ? 'bg-brand-50 text-brand-700 dark:bg-ink-800 dark:text-brand-300'
                        : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-ink-800 dark:hover:text-white',
                    ]}
                  >
                    {hobby.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </li>

        <li>
          <a
            href={contactLink.href}
            aria-current={isActive(contactLink.href) ? 'page' : undefined}
            class:list={linkClasses(isActive(contactLink.href))}
          >
            {contactLink.label}
          </a>
        </li>
      </ul>

      <ThemeToggle />

      <button
        id="mobile-menu-button"
        type="button"
        class="rounded-lg p-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 md:hidden dark:text-slate-300 dark:hover:bg-ink-900 dark:hover:text-white"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-200/70 md:hidden dark:border-ink-800/70">
    <ul class="space-y-1 px-4 py-3">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm font-medium',
                isActive(link.href)
                  ? 'bg-brand-50 text-brand-700 dark:bg-ink-900 dark:text-brand-300'
                  : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-ink-900 dark:hover:text-white',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }

      <li>
        <span class="block px-3 pb-1 pt-2 text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500">
          Hobbies
        </span>
        <ul class="ml-3 space-y-1 border-l border-slate-200 pl-2 dark:border-ink-800">
          {
            hobbies.map((hobby) => (
              <li>
                <a
                  href={hobby.href}
                  aria-current={isActive(hobby.href) ? 'page' : undefined}
                  class:list={[
                    'block rounded-lg px-3 py-2 text-sm font-medium',
                    isActive(hobby.href)
                      ? 'bg-brand-50 text-brand-700 dark:bg-ink-900 dark:text-brand-300'
                      : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-ink-900 dark:hover:text-white',
                  ]}
                >
                  {hobby.label}
                </a>
              </li>
            ))
          }
        </ul>
      </li>

      <li>
        <a
          href={contactLink.href}
          aria-current={isActive(contactLink.href) ? 'page' : undefined}
          class:list={[
            'block rounded-lg px-3 py-2 text-sm font-medium',
            isActive(contactLink.href)
              ? 'bg-brand-50 text-brand-700 dark:bg-ink-900 dark:text-brand-300'
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-ink-900 dark:hover:text-white',
          ]}
        >
          {contactLink.label}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  button?.addEventListener('click', () => {
    const isOpen = !menu?.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(isOpen));
  });

  // Hobbies dropdown: click to toggle, close on outside click or Escape
  const hobbiesButton = document.getElementById('hobbies-button');
  const hobbiesDropdown = document.getElementById('hobbies-dropdown');
  const hobbiesRoot = document.getElementById('hobbies-root');

  const setOpen = (open: boolean) => {
    hobbiesDropdown?.classList.toggle('hidden', !open);
    hobbiesButton?.setAttribute('aria-expanded', String(open));
    hobbiesButton?.querySelector('svg')?.classList.toggle('rotate-180', open);
  };

  hobbiesButton?.addEventListener('click', () => {
    setOpen(hobbiesDropdown?.classList.contains('hidden') ?? false);
  });
  document.addEventListener('click', (e) => {
    if (!hobbiesRoot?.contains(e.target as Node)) setOpen(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
