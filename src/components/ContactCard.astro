---
import contact from '../data/contact.json';

const items = [
  {
    label: 'Email',
    href: contact.email ? `mailto:${contact.email}` : '',
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
  },
  {
    label: 'GitHub',
    href: contact.github,
    icon: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
  },
  {
    label: 'LinkedIn',
    href: contact.linkedin,
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    label: 'Google Scholar',
    href: contact.scholar,
    icon: 'M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  },
  {
    label: contact.location,
    href: '',
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
].filter((item) => item.label && (item.href || item.label === contact.location));
---

<div class="grid gap-4 sm:grid-cols-2">
  {
    items.map((item) => {
      const Tag = item.href ? 'a' : 'div';
      return (
        <Tag
          href={item.href || undefined}
          target={item.href && !item.href.startsWith('mailto:') ? '_blank' : undefined}
          rel={item.href && !item.href.startsWith('mailto:') ? 'noopener noreferrer' : undefined}
          class:list={[
            'reveal flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-ink-800 dark:bg-ink-900/60',
            item.href &&
              'transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-lg dark:hover:border-brand-700',
          ]}
        >
          <span
            class="inline-flex shrink-0 rounded-xl bg-brand-50 p-3 text-brand-600 dark:bg-ink-800 dark:text-brand-400"
            aria-hidden="true"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </span>
          <span class="min-w-0 truncate text-sm font-semibold text-slate-900 dark:text-white">
            {item.label}
          </span>
        </Tag>
      );
    })
  }
</div>
