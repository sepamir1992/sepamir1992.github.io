---
import profile from '../data/profile.json';

const ctas = [
  { href: '/projects/', label: 'View Projects', style: 'primary' },
  { href: '/publications/', label: 'Publications', style: 'secondary' },
  { href: '/photography/', label: 'Photography', style: 'secondary' },
  { href: '/contact/', label: 'Contact', style: 'ghost' },
];
---

<section class="relative overflow-hidden bg-ink-950 text-white">
  <!-- Decorative background: subtle grid + glow gradients -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0 opacity-[0.07]"
      style="background-image: linear-gradient(to right, #5072a1 1px, transparent 1px), linear-gradient(to bottom, #5072a1 1px, transparent 1px); background-size: 48px 48px;"
    >
    </div>
    <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-brand-600/25 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-24 h-96 w-96 rounded-full bg-accent-500/15 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_auto]">
      <div>
        <p class="mb-4 text-sm font-bold uppercase tracking-widest text-accent-400">
          {profile.title} · {profile.affiliation}
        </p>
        <h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl">
          {profile.name}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-200 sm:text-xl">
          {profile.tagline}
        </p>

        <ul class="mt-8 flex flex-wrap gap-2" aria-label="Research focus areas">
          {
            profile.badges.map((badge) => (
              <li class="rounded-full border border-ink-700 bg-ink-900/60 px-3.5 py-1.5 text-sm font-medium text-ink-200 backdrop-blur-sm transition-colors hover:border-brand-500 hover:text-white">
                {badge}
              </li>
            ))
          }
        </ul>

        <div class="mt-10 flex flex-wrap gap-3">
          {
            ctas.map((cta) => (
              <a
                href={cta.href}
                class:list={[
                  'rounded-xl px-5 py-3 text-sm font-semibold transition-all',
                  cta.style === 'primary' &&
                    'bg-brand-600 text-white shadow-lg shadow-brand-600/30 hover:-translate-y-0.5 hover:bg-brand-500',
                  cta.style === 'secondary' &&
                    'border border-ink-600 bg-ink-900/60 text-white hover:-translate-y-0.5 hover:border-brand-500 hover:bg-ink-800',
                  cta.style === 'ghost' && 'px-4 text-ink-200 hover:text-white',
                ]}
              >
                {cta.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="hidden justify-self-center lg:block">
        <div class="relative">
          <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-brand-500/40 to-accent-500/40 blur-xl" aria-hidden="true"></div>
          <img
            src={profile.headshot}
            alt={`Portrait of ${profile.name}`}
            width="384"
            class="relative w-96 rounded-3xl border border-ink-700 shadow-2xl"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="relative pb-8 text-center" aria-hidden="true">
    <svg class="mx-auto h-6 w-6 animate-bounce text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
