---
import profile from '../data/profile.json';
import contact from '../data/contact.json';

const year = new Date().getFullYear();

const socials = [
  { label: 'GitHub', href: contact.github },
  { label: 'LinkedIn', href: contact.linkedin },
  { label: 'Google Scholar', href: contact.scholar },
  { label: 'Email', href: contact.email ? `mailto:${contact.email}` : '' },
].filter((s) => s.href);
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-ink-800 dark:bg-ink-900/40">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-10 sm:flex-row sm:justify-between sm:px-6">
    <div class="text-center sm:text-left">
      <p class="font-semibold text-slate-900 dark:text-white">{profile.name}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400">
        {profile.title}, {profile.affiliation}
      </p>
    </div>

    <nav aria-label="Social links">
      <ul class="flex flex-wrap items-center justify-center gap-4">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.href.startsWith('mailto:') ? undefined : '_blank'}
                rel="noopener noreferrer"
                class="text-sm font-medium text-slate-500 transition-colors hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
              >
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <div class="border-t border-slate-200 py-4 text-center text-xs text-slate-400 dark:border-ink-800 dark:text-slate-500">
    © {year} {profile.name}. All rights reserved.
  </div>
</footer>
